{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/finance-agent",
      "destination": "/agent"
    },
    {
      "source": "/login",
      "destination": "/auth/signin"
    },
    {
      "source": "/register",
      "destination": "/auth/signup"
    },
    {
      "source": "/plans",
      "destination": "/pricing"
    }
  ]
}