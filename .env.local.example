# PHLedger — local dev environment
# Copy this file to .env.local and fill in your values
# .env.local is gitignored and NEVER committed to Git

# ─── Supabase (optional — app falls back to CSV files if omitted) ────
# Get these from: https://supabase.com/dashboard/project/dtfbcvefttirngkjuqvl/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://dtfbcvefttirngkjuqvl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key-here>
# For server-side API routes (service_role — keep private, server only):
SUPABASE_URL=https://dtfbcvefttirngkjuqvl.supabase.co
SUPABASE_KEY=<your-service-role-key-here>

# ─── Next.js ────────────────────────────────────────────────────────
# No extra Next.js vars needed for local dev

# ─── Setup steps ────────────────────────────────────────────────────
# 1. cp .env.local.example .env.local
# 2. Fill in SUPABASE_URL + SUPABASE_KEY from Supabase dashboard
# 3. npm run dev  →  http://localhost:3000
# 4. Upload a CSV — it will upsert to Supabase AND work offline (CSV fallback)
